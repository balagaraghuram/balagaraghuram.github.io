<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Request Blocked</title>
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">
<style>
body{background-color:#000;color:#fff;font-family:-apple-system,"Helvetica Neue",Helvetica,"Segoe UI",Arial,sans-serif;font-size:13px;line-height:1.52857}
body .main-wrap{width:90%;margin-left:auto;margin-right:auto}
h1,h2,h3,h4,h5,h6{font-family:inherit;font-weight:500;line-height:1.6;color:#fff}
hr{margin-top:19px;margin-bottom:19px;border:0;border-top:1px solid #383838}
.panel-body{padding:15px}.panel-body:after,.panel-body:before{content:" ";display:table}
.panel-body:after{clear:both}
.panel-heading{padding:10px 15px;border-bottom:1px solid transparent;border-top-right-radius:2px;border-top-left-radius:2px}
.panel-title{margin-top:0;margin-bottom:0;font-size:15px;color:inherit}
.panel-footer{padding:10px 15px;background-color:#282828;border-top:1px solid #262626;border-bottom-right-radius:2px;border-bottom-left-radius:2px}
.b-gray-dark{border-color:#2d2d2d!important}
.b-a-2{border:2px solid #262626!important}
.b-gray{border-color:#383838!important}
.bg-gray-dark{background-color:#2d2d2d!important}
.panel{margin-bottom:19px;background-color:#1A1A1A;border:1px solid transparent;border-radius:3px;box-shadow:0 1px 1px rgba(0,0,0,.05)}
.panel-default{border-color:#262626}
.panel-default>.panel-heading{color:#fff;background-color:transparent;border-color:#262626}
dt{color:#999}
a{color:#00D87A;text-decoration:none}
a:hover,a:visited{color:#00D87A;text-decoration:none}
</style>
<script id='blockOfStuff' language="text">
</script>
<script lang="javascript">
    var trans = "68261550-PPE2";
    var sessionid = "AAI7KMBFajtgiwQAAAAAADvKXKK17QYwXbAHOzmU1n7DG-zjgHx_-tQnMoK1xwqQOw==";

    function setInnerHTML()  {
      x = document.getElementById("transid");
      x.innerHTML = trans;
    }
  </script>
</head>
<body onload="setInnerHTML()">
<div class="main-wrap">
<div class="row">
<div class="col-md-8 col-md-offset-2">
<h4><span class="glyphicon glyphicon-alert" aria-hidden="true"></span> Request Blocked</h4>
<p>This request was blocked by the Web Application Firewall.</p>
<div class="panel panel-default b-a-2 b-gray bg-gray-dark">
<div class="panel-heading">
<div class="panel-title">Blocked Request Details</div>
</div>
<div class="panel-body">
  <dl class="dl-horizontal">
    <dt>Transaction ID</dt>
    <dd id="transid"></dd>
  </dl>
</div>
<div class="panel-footer text-right">
<p>If you believe this block to be in error , please contact the Site Admin with the above information</p>
</div>
</div>
</div>
</div>
</div>
</body>
</html>
